{
  "name": "pullframe",
  "version": "1.0.2",
  "description": "Cross-platform YouTube downloader — Electron + React + yt-dlp",
  "main": "./out/main/index.js",
  "author": "Hutson Cappelmann",
  "license": "GPL-3.0",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "prebuild:bins": "node scripts/download-binaries.mjs current --force",
    "package": "npm run prebuild:bins && electron-vite build && electron-builder --config electron-builder.yml",
    "package:mac": "npm run prebuild:bins && electron-vite build && electron-builder --mac --config electron-builder.yml",
    "package:official": "MAIN_VITE_OFFICIAL_BUILD=1 npm run package",
    "package:mac:official": "MAIN_VITE_OFFICIAL_BUILD=1 npm run package:mac && scripts/finalize-mac-release.sh",
    "release:notes": "node scripts/build-release-notes.mjs",
    "publish:nexus": "scripts/publish-nexus-release.sh",
    "release:nexus": "npm run package:mac:official && npm run publish:nexus",
    "release:from-tag": "scripts/release-from-tag.sh",
    "release:ci:preflight": "scripts/ci-release-preflight.sh",
    "release:verify:artifacts": "scripts/verify-release-artifacts.sh",
    "release:verify:feeds": "scripts/verify-release-feeds.sh",
    "release:evidence": "node scripts/write-release-evidence.mjs",
    "test:release": "node scripts/test-release-notes.mjs && node scripts/test-public-export.mjs && scripts/publish-nexus-release-test.sh && scripts/release-from-tag-test.sh && node scripts/test-ci-release-scripts.mjs",
    "test:release-from-tag": "scripts/release-from-tag-test.sh",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "tree-kill": "^1.2.2",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.49",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
